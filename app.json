{
  "expo": {
    "name": "yolbelet-app",
    "slug": "yolbelet-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.menli.yolbeletapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Programma siziň ýerleşýän ýeriňizi karta görkezmek we paýlaşmak üçin GPS ulanmaly.",
        "NSLocationAlwaysUsageDescription": "Programma azaşmazlygyňyz üçin yzyňyzdaky ýoly hemişe yzarlamaly."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.menli.yolbeletapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "ACCESS_BACKGROUND_LOCATION",
        "SEND_SMS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "" 
        }
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Ýolbelet siziň ýoluňyzy yzarlamak üçin hemişe GPS ulanmaly."
        }
      ]
    ],
    "owner": "mahrimenli"
  }
}
