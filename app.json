{
  "expo": {
    "name": "Yolbelet",
    "slug": "yolbelet-app",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1d3557"
      },
      "package": "com.menli.yolbeletapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "SEND_SMS",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Yolbelet siziň ýoluňyzy ýzarlamak üçin GPS ulanmaly."
        }
      ]
    ]
  }
}
